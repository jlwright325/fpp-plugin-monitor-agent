        "/home/fpp/media/config/fpp-monitor-agent.json",
        "fpp-monitor-agent.service"
      ]
    },
    {
      "file": "system/fpp-monitor-agent.sh",
      "mustContain": [
        "/home/fpp/media/config/fpp-monitor-agent.json",
        "/opt/fpp-monitor-agent/fpp-monitor-agent"
      ]
    },
    {
      "file": "system/fpp-monitor-agent.service",
