{
  "contractVersion": "1.1.0",
  "description": "Machine-readable checks for docs/PLUGIN_API_CONTRACT.md. CI fails if plugin paths or UI POST actions drift without updating the contract.",
  "frozenPaths": {
    "userConfigFile": "/home/fpp/media/config/fpp-monitor-agent.json",
    "pluginInstallDir": "/home/fpp/media/plugins/showops-agent",
    "systemdUnitFileName": "fpp-monitor-agent.service",
    "optAgentBinary": "/opt/fpp-monitor-agent/fpp-monitor-agent"
  },
  "pluginUiPostActions": ["pair", "unpair", "restart", "tail"],
